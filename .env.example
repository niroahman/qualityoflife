# Cloudflare Access (service token)
CF_ACCESS_CLIENT_ID=your-client-id.access
CF_ACCESS_CLIENT_SECRET=your-client-secret

# SilverBullet
SB_BASE_URL=https://your-silverbullet-domain.com
SB_USER=your-username
SB_PASSWORD=your-password
SB_SPACE_PATH=Digest

# AI (Gemini CLI uses OAuth — key optional if signed in)
GEMINI_API_KEY=your-gemini-api-key

# Feedparser
FEED_MAX_ITEMS=5
FEED_MAX_DESC_CHARS=400
FEED_TIMEOUT_SECS=10

# SSL (set automatically by setup, or point to your certifi cacert.pem)
# SSL_CERT_FILE=/path/to/certifi/cacert.pem
