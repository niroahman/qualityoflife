        "inputSchema": "{\n  \"type\": \"object\",\n  \"properties\": {\n    \"score\": { \"type\": \"number\", \"minimum\": 1, \"maximum\": 10 },\n    \"reasoning\": { \"type\": \"string\" },\n    \"tags\": { \"type\": \"array\", \"items\": { \"type\": \"string\" } }\n  },\n  \"required\": [\"score\", \"reasoning\", \"tags\"],\n  \"additionalProperties\": false\n}"
      },
