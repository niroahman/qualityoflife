      "parameters": {
        "promptType": "define",
        "text": "=Title: {{ $json.title }}\nSource: {{ $json.creator || $json[\"dc:creator\"] || $json.feedUrl }}\nSnippet: {{ $json.contentSnippet }}",
        "hasOutputParser": true,
        "messages": {
          "messageValues": [
            {
              "message": "You are curating a personalized weekly tech digest for a senior fullstack engineer interested in AI-native development, agentic systems, developer tooling, homelab infrastructure, software craftsmanship, and workflow automation platforms like n8n. Score each item 1-10 for personal relevance: - 10: must-read, directly actionable or novel, or highly relevant to AI-native dev or n8n - 8-9: strong relevance, worth a click - 6-7: tangentially relevant, skippable when busy - 4-5: low relevance - 1-3: noise Penalize: hype, listicles, generic X-tips-for-Y, repackaged news. Reward: technical depth, original analysis, production build logs. Return only valid JSON, no markdown fences, no prose."
            }
          ]
        },
        "batching": {}
      },
