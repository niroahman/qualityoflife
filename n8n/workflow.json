    {
      "parameters": {
        "jsCode": "const llmItems = $input.all();\nconst sourceItems = $('Merge').all();\n\nreturn llmItems.map((item, i) => {\n  const source = sourceItems[i]?.json ?? {};\n  return {\n    json: {\n      ...source,           // title, link, contentSnippet, etc\n      ...item.json,        // score, reasoning, tags\n    }\n  };\n});"
      },
