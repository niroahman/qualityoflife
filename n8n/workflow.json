      "id": "5975d1e9-f8d1-4993-b96b-bd690077ffa6",
      "name": "Schedule Trigger"
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nif (items.length === 0) {\n  return [{ json: { digest: 'No items above threshold this week.' } }];\n}\n\nconst top = items\n  .map(i => i.json)\n  .sort((a, b) => b.score - a.score)\n  .slice(0, 5);\n\nconst now = new Date().toISOString().split('T')[0];\nconst lines = [`*Tech digest — ${now}*`, ''];\n\nfor (const { title, link, output } of top) {\n  const { score, reasoning, tags} = output\n  const shortReasoning = (reasoning || '').split(/(?<=[.!?])\\s+/)[0];\n  const tagStr = (tags || []).slice(0, 3).map(t => `\\`${t}\\``).join(' ');\n\n  lines.push(`*${score}/10* — [${title}](${link})`);\n  lines.push(`_${shortReasoning}_`);\n  if (tagStr) lines.push(tagStr);\n  lines.push('');\n}\n\nreturn [{ json: { digest: lines.join('\\n') } }];"
      },
      "type": "n8n-nodes-base.code",
